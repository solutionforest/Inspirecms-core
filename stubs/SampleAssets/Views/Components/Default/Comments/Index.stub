    <!-- Comments List -->
    <h3 class="comment-h3">Commments</h3>
    <div class="comments-list">
        <!-- Comment 1 with its reply -->
        @foreach ($comments as $comment)
            <x-dynamic-component :component="\SolutionForest\InspireCms\InspireCmsConfig::getComponentWithTheme('comments.comment')" 
                :author="$comment['author']"
                :date="$comment['date']"
                :content="$comment['content']"
                :replies="$comment['replies'] ?? []"
            />
        @endforeach
    </div>
