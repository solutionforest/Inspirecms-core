@php
    $locale ??= request()->getLocale();
    $nav = inspirecms()->getNavigation('main', $locale);
    $allLocales = collect(inspirecms()->getAllAvailableLanguages())
      ->mapWithKeys(fn ($item) => [$item->code => $item->getLabel($locale)])
      ->all();
@endphp

<!-- top nav -->
<nav class="top-main-nav">
    @foreach ($nav as $item)
        <a class="nav-item" href="{{ $item->getUrl() }}">{{ $item->getTitle() }}</a>
    @endforeach
</nav>