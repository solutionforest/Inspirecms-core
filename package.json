{
    "private": true,
    "type": "module",
    "scripts": {
        "dev:code-editor-css": "npx @tailwindcss/cli -i ./resources/css/components/code-editor.css -o ./resources/dist/components/code-editor.css --watch",
        "dev:alert-css": "npx @tailwindcss/cli -i ./resources/css/components/alert.css -o ./resources/dist/components/alert.css --watch",
        "dev:main-css": "npx @tailwindcss/cli -i ./resources/css/index.css -o ./resources/dist/inspirecms.css --watch",
        "dev:styles": "npm run dev:main-css && npm run dev:code-editor-css && npm run dev:alert-css",
        "dev:scripts": "node ./bin/build.js --dev",
        "build:code-editor-css": "npx @tailwindcss/cli -i ./resources/css/components/code-editor.css -o ./resources/dist/components/code-editor.css  --minify",
        "build:alert-css": "npx @tailwindcss/cli  -i ./resources/css/components/alert.css -o ./resources/dist/components/alert.css --minify",
        "build:main-css": "npx @tailwindcss/cli -i ./resources/css/index.css -o ./resources/dist/inspirecms.css --minify",
        "build:styles": "npm run build:main-css && npm run build:code-editor-css && npm run build:alert-css",
        "build:scripts": "node ./bin/build.js",
        "purge": "filament-purge -i resources/dist/inspirecms.css -o resources/dist/inspirecms.css -v 3.x",
        "dev": "npm run dev:styles && npm run dev:scripts",
        "build": "npm run build:styles && npm run build:scripts"
    },
    "devDependencies": {
        "@awcodes/filament-plugin-purge": "^1.1.1",
        "@tailwindcss/forms": "^0.5.4",
        "@tailwindcss/postcss": "^4.1.11",
        "@tailwindcss/typography": "^0.5.9",
        "esbuild": "^0.19.2",
        "npm-run-all": "^4.1.5",
        "postcss": "^8.5.3",
        "postcss-cli": "^11.0.1",
        "postcss-preset-env": "^10.1.5",
        "prettier": "^3.6.2",
        "prettier-plugin-tailwindcss": "^0.6.14",
        "tailwindcss": "^4.1.11"
    },
    "dependencies": {
        "@codemirror/commands": "^6.8.1",
        "@codemirror/lang-cpp": "^6.0.3",
        "@codemirror/lang-css": "^6.3.1",
        "@codemirror/lang-go": "^6.0.1",
        "@codemirror/lang-html": "^6.4.9",
        "@codemirror/lang-java": "^6.0.2",
        "@codemirror/lang-javascript": "^6.2.3",
        "@codemirror/lang-json": "^6.0.1",
        "@codemirror/lang-markdown": "^6.3.3",
        "@codemirror/lang-php": "^6.0.1",
        "@codemirror/lang-python": "^6.2.1",
        "@codemirror/lang-xml": "^6.1.0",
        "@codemirror/lang-yaml": "^6.1.2",
        "@codemirror/state": "^6.5.2",
        "@codemirror/theme-one-dark": "^6.1.2",
        "@codemirror/view": "^6.36.6",
        "@fsegurai/codemirror-theme-bundle": "^6.2.0-beta",
        "@tiptap/core": "^3.4.3",
        "codemirror": "^5.65.8",
        "codemirror-v6": "npm:codemirror@^6.0.1"
    }
}
